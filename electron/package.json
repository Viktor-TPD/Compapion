{
  "name": "compapion-electron",
  "version": "0.1.0",
  "description": "Compapion desktop tray app",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc --watch & electron .",
    "build": "tsc",
    "dist": "tsc && electron-builder",
    "dev:windows": "powershell -ExecutionPolicy Bypass -File sync-from-wsl.ps1 && tsc && electron-builder --win --x64 --dir",
    "dist:windows": "powershell -ExecutionPolicy Bypass -File sync-from-wsl.ps1 && tsc && electron-builder --win --x64",
    "sync:addon": "powershell -ExecutionPolicy Bypass -Command \"$env:SYNC_ADDON='1'; & '.\\sync-from-wsl.ps1'\""
  },
  "build": {
    "forceCodeSigning": false,
    "appId": "com.compapion.app",
    "productName": "Compapion",
    "win": {
      "target": "zip",
      "icon": "assets/icon.png"
    },
    "files": [
      "dist/**/*",
      "assets/*",
      "ui/**/*",
      "addon/**/*"
    ],
    "asarUnpack": [
      "assets/**/*",
      "ui/**/*",
      "addon/**/*"
    ]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "chokidar": "^3.6.0",
    "fengari": "^0.1.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "electron": "31.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.0.0"
  }
}
